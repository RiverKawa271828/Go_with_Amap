<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ============================================ -->
    <!-- Material Design 3 深色主题 -->
    <!-- ============================================ -->
    <style name="AppTheme" parent="Theme.Material3.Dark.NoActionBar">
        <!-- 品牌色 -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_onPrimaryContainer</item>
        
        <!-- 次要色 -->
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/md_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_onSecondaryContainer</item>
        
        <!-- 第三色 -->
        <item name="colorTertiary">@color/md_tertiary</item>
        <item name="colorOnTertiary">@color/md_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_onTertiaryContainer</item>
        
        <!-- 错误色 -->
        <item name="colorError">@color/md_error</item>
        <item name="colorOnError">@color/md_onError</item>
        <item name="colorErrorContainer">@color/md_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_onErrorContainer</item>
        
        <!-- 表面色 -->
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_onSurfaceVariant</item>
        
        <!-- 背景色 -->
        <item name="android:colorBackground">@color/md_background</item>
        <item name="colorOnBackground">@color/md_onBackground</item>
        
        <!-- 轮廓色 -->
        <item name="colorOutline">@color/md_outline</item>
        
        <!-- 状态栏和导航栏 - 深色主题 -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">false</item>
        
        <!-- 组件样式覆盖 -->
        <item name="materialButtonStyle">@style/AppTheme.Button</item>
        <item name="materialButtonOutlinedStyle">@style/AppTheme.Button.Outlined</item>
        <item name="materialCardViewStyle">@style/AppTheme.Card</item>
        <item name="textInputStyle">@style/AppTheme.TextInput</item>
        <item name="toolbarStyle">@style/AppTheme.Toolbar</item>
        <item name="appBarLayoutStyle">@style/AppTheme.AppBar</item>
        
        <!-- 对话框主题 -->
        <item name="alertDialogTheme">@style/AppTheme.Dialog</item>
        <item name="dialogTheme">@style/AppTheme.Dialog</item>
        
        <!-- 浮动操作按钮 -->
        <item name="floatingActionButtonStyle">@style/AppTheme.FAB</item>
        
        <!-- 开关和复选框 -->
        <item name="switchStyle">@style/AppTheme.Switch</item>
        <item name="checkboxStyle">@style/AppTheme.Checkbox</item>
        
        <!-- 涟漪效果 -->
        <item name="android:colorControlHighlight">#33FFFFFF</item>
    </style>

    <!-- 无ActionBar变体 -->
    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    
    <!-- 带ActionBar变体 -->
    <style name="AppTheme.WithActionBar" parent="Theme.Material3.Dark">
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_onPrimaryContainer</item>
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/md_onSecondary</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_onSurface</item>
        <item name="android:colorBackground">@color/md_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="materialButtonStyle">@style/AppTheme.Button</item>
        <item name="materialCardViewStyle">@style/AppTheme.Card</item>
    </style>

    <!-- ============================================ -->
    <!-- 工具栏样式 - 使用深黑绿色 -->
    <!-- ============================================ -->
    <style name="AppTheme.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/md_surfaceDarkGreen</item>
        <item name="titleTextColor">@color/md_onSurface</item>
        <item name="subtitleTextColor">@color/md_onSurface</item>
        <item name="elevation">0dp</item>
        <item name="titleTextAppearance">@style/TextAppearance.ToolbarTitle</item>
        <item name="navigationIconTint">@color/md_onSurface</item>
    </style>
    
    <style name="AppTheme.AppBar" parent="Widget.Material3.AppBarLayout">
        <item name="android:background">@color/md_surfaceDarkGreen</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- ============================================ -->
    <!-- 按钮样式 -->
    <!-- ============================================ -->
    <style name="AppTheme.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/md_primary</item>
        <item name="android:textColor">@color/md_onPrimary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="cornerRadius">20dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:minHeight">48dp</item>
    </style>
    
    <style name="AppTheme.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/md_outline</item>
        <item name="android:textColor">@color/md_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">20dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>
    
    <style name="AppTheme.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/md_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="cornerRadius">8dp</item>
    </style>
    
    <style name="AppTheme.Button.Secondary" parent="AppTheme.Button">
        <item name="backgroundTint">@color/md_secondaryContainer</item>
        <item name="android:textColor">@color/md_onSecondaryContainer</item>
    </style>
    
    <style name="AppTheme.Button.Error" parent="AppTheme.Button">
        <item name="backgroundTint">@color/md_errorContainer</item>
        <item name="android:textColor">@color/md_onErrorContainer</item>
    </style>

    <!-- ============================================ -->
    <!-- 卡片样式 -->
    <!-- ============================================ -->
    <style name="AppTheme.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/md_surfaceContainerLowest</item>
        <item name="cardElevation">1dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="contentPadding">16dp</item>
        <item name="strokeWidth">0dp</item>
    </style>
    
    <style name="AppTheme.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@color/md_surfaceContainerLowest</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="contentPadding">16dp</item>
        <item name="strokeColor">@color/md_outlineVariant</item>
        <item name="strokeWidth">1dp</item>
    </style>
    
    <style name="AppTheme.Card.Filled" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/md_surfaceContainer</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- ============================================ -->
    <!-- 输入框样式 -->
    <!-- ============================================ -->
    <style name="AppTheme.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/md_outline</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/md_onSurfaceVariant</item>
        <item name="android:textColorHint">@color/md_onSurfaceVariant</item>
        <item name="endIconTint">@color/md_onSurfaceVariant</item>
        <item name="startIconTint">@color/md_onSurfaceVariant</item>
    </style>
    
    <style name="AppTheme.TextInput.Filled" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/md_surfaceContainer</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- ============================================ -->
    <!-- 对话框样式 -->
    <!-- ============================================ -->
    <style name="AppTheme.Dialog" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="colorSurface">@color/md_surfaceContainerHigh</item>
        <item name="android:windowBackground">@drawable/dialog_rounded_background</item>
        <item name="android:windowMinWidthMajor">85%</item>
        <item name="android:windowMinWidthMinor">85%</item>
    </style>
    
    <style name="AppTheme.Dialog.Rounded">
        <item name="android:windowBackground">@drawable/dialog_rounded_background</item>
        <item name="android:windowMinWidthMajor">80%</item>
        <item name="android:windowMinWidthMinor">80%</item>
    </style>

    <!-- ============================================ -->
    <!-- 浮动操作按钮 -->
    <!-- ============================================ -->
    <style name="AppTheme.FAB" parent="Widget.Design.FloatingActionButton">
        <item name="backgroundTint">@color/md_primaryContainer</item>
        <item name="tint">@color/md_onPrimaryContainer</item>
        <item name="elevation">2dp</item>
        <item name="pressedTranslationZ">4dp</item>
    </style>
    
    <style name="AppTheme.FAB.Secondary" parent="Widget.Design.FloatingActionButton">
        <item name="backgroundTint">@color/md_secondaryContainer</item>
        <item name="tint">@color/md_onSecondaryContainer</item>
    </style>
    
    <style name="AppTheme.FAB.Small" parent="Widget.Design.FloatingActionButton">
        <item name="fabSize">mini</item>
        <item name="backgroundTint">@color/md_primaryContainer</item>
        <item name="tint">@color/md_onPrimaryContainer</item>
    </style>

    <!-- ============================================ -->
    <!-- 开关和复选框 -->
    <!-- ============================================ -->
    <style name="AppTheme.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">@color/md_primary</item>
        <item name="trackTint">@color/md_primaryContainer</item>
    </style>
    
    <style name="AppTheme.Checkbox" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">@color/md_primary</item>
    </style>
    
    <style name="AppTheme.RadioButton" parent="Widget.Material3.CompoundButton.RadioButton">
        <item name="buttonTint">@color/md_primary</item>
    </style>

    <!-- ============================================ -->
    <!-- 文字外观 -->
    <!-- ============================================ -->

    
    <style name="TextAppearance.Button" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/md_onPrimary</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- ============================================ -->
    <!-- 动画 -->
    <!-- ============================================ -->
    <style name="AppTheme.Animation" parent="android:Animation">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>
    
    <style name="AppTheme.Animation.Slide">
        <item name="android:windowEnterAnimation">@android:anim/slide_in_left</item>
        <item name="android:windowExitAnimation">@android:anim/slide_out_right</item>
    </style>
    
    <style name="AppTheme.Animation.BottomSheet">
        <item name="android:windowEnterAnimation">@anim/slide_up</item>
        <item name="android:windowExitAnimation">@anim/slide_down</item>
    </style>

    <!-- ============================================ -->
    <!-- 特殊组件样式 -->
    <!-- ============================================ -->
    <style name="AppTheme.SearchView" parent="Widget.AppCompat.SearchView">
        <item name="background">@drawable/search_view_background</item>
        <item name="elevation">0dp</item>
    </style>
    
    <style name="AppTheme.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="itemIconTint">#5A7A6A</item>
        <item name="itemTextColor">#8A9A8E</item>
        <item name="itemBackground">@drawable/navigation_item_background</item>
        <item name="itemHorizontalPadding">16dp</item>
        <item name="itemVerticalPadding">12dp</item>
    </style>
    
    <style name="AppTheme.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/md_surfaceContainer</item>
        <item name="itemIconTint">@color/md_onSurfaceVariant</item>
        <item name="itemTextColor">@color/md_onSurfaceVariant</item>
        <item name="itemActiveIndicatorStyle">@style/AppTheme.BottomNavigation.ActiveIndicator</item>
    </style>
    
    <style name="AppTheme.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/md_secondaryContainer</item>
    </style>
    
    <style name="AppTheme.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/md_primary</item>
        <item name="tabSelectedTextColor">@color/md_primary</item>
        <item name="tabTextColor">@color/md_onSurfaceVariant</item>
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabIndicatorFullWidth">false</item>
        <item name="tabIndicatorAnimationMode">elastic</item>
    </style>
    
    <style name="AppTheme.Chip" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/md_surfaceContainer</item>
        <item name="chipStrokeColor">@color/md_outlineVariant</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/md_onSurface</item>
    </style>
    
    <style name="AppTheme.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/md_secondaryContainer</item>
        <item name="android:textColor">@color/md_onSecondaryContainer</item>
    </style>
    
    <style name="AppTheme.Slider" parent="Widget.Material3.Slider">
        <item name="trackColorActive">@color/md_primary</item>
        <item name="trackColorInactive">@color/md_surfaceVariant</item>
        <item name="thumbColor">@color/md_primary</item>
    </style>
    
    <style name="AppTheme.ProgressIndicator" parent="Widget.Material3.CircularProgressIndicator">
        <item name="indicatorColor">@color/md_primary</item>
        <item name="trackColor">@color/md_surfaceVariant</item>
        <item name="indicatorSize">48dp</item>
        <item name="strokeWidth">4dp</item>
    </style>
    
    <style name="AppTheme.Divider" parent="">
        <item name="android:background">@color/md_outlineVariant</item>
        <item name="android:layout_height">1dp</item>
    </style>
    
    <style name="AppTheme.ListItem" parent="">
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- 向后兼容的样式 -->
    <style name="TextAppearance.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/md_onSurface</item>
    </style>

    <style name="RippleWhite">
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
    </style>
    
    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar">
        <item name="android:background">@color/md_primary</item>
    </style>
    
    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.Material3.Dark">
        <item name="android:colorBackground">@color/md_surface</item>
    </style>

    <style name="DialogAnimFadeInFadeOut">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

</resources>
