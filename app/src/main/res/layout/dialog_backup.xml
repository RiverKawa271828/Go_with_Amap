<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/radius_xl"
    app:cardElevation="@dimen/elevation_high"
    app:cardBackgroundColor="@color/backgroundCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_2xl">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="备份数据"
            android:textAppearance="@style/TextAppearance.Title"
            android:textColor="@color/textPrimary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- 切换按钮 - 导出/导入 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/md_surfaceContainer"
            android:layout_marginBottom="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_xs">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_export"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="导出"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/md_onSurface"
                    app:backgroundTint="@color/md_primary"
                    app:cornerRadius="@dimen/radius_sm"
                    android:elevation="2dp"
                    android:shadowColor="#40000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="4" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_import"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="导入"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/md_onSurfaceVariant"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/radius_sm"
                    android:elevation="0dp" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 导出容器 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/container_export"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="@color/backgroundLight"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp">

            <ListView
                android:id="@+id/lv_backup_files"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:padding="0dp"
                android:scrollbars="vertical" />

        </com.google.android.material.card.MaterialCardView>

        <!-- 导入容器 - 默认隐藏 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/container_import"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginBottom="@dimen/spacing_md"
            android:visibility="gone"
            app:cardBackgroundColor="@color/backgroundLight"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_select_file"
                    style="@style/AppTheme.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/spacing_md"
                    android:text="从文件选择" />

                <ListView
                    android:id="@+id/lv_import_files"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:divider="@null"
                    android:dividerHeight="0dp"
                    android:padding="0dp"
                    android:scrollbars="vertical" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 提示文字 -->
        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="点击选择备份文件，长按可多选"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/textTertiary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_xl" />

        <!-- 导出按钮区域 -->
        <LinearLayout
            android:id="@+id/layout_export_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_backup"
                style="@style/AppTheme.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="删除"
                android:visibility="gone"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_export_backup"
                style="@style/AppTheme.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="导出备份" />

        </LinearLayout>

        <!-- 导入按钮区域 - 默认隐藏 -->
        <LinearLayout
            android:id="@+id/layout_import_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_import_overwrite"
                style="@style/AppTheme.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="覆盖"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_import_incremental"
                style="@style/AppTheme.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="增量"
                android:layout_marginStart="@dimen/spacing_sm" />

        </LinearLayout>

        <!-- 关闭按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_close"
            style="@style/AppTheme.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="关闭"
            android:layout_marginTop="@dimen/spacing_md" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
