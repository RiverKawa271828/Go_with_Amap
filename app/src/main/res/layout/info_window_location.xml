<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#F2FFFFFF">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 标题栏 - 居中 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- 模拟状态指示点 -->
            <View
                android:id="@+id/iv_simulation_status"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginTop="3dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/circle_shape_normal"
                android:visibility="gone" />

            <!-- 位置名称 - 支持换行，点击复制 -->
            <TextView
                android:id="@+id/tv_location_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/textPrimary"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingMultiplier="1.05"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="位置名称"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <!-- 已收藏图标 -->
            <ImageView
                android:id="@+id/iv_favorite_status"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_favorite"
                android:visibility="gone"
                app:tint="@color/md_tertiary" />
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="@color/md_outlineVariant" />

        <!-- 坐标信息 - 居中 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- GCJ02坐标 - 点击复制 -->
            <TextView
                android:id="@+id/tv_gcj02"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/textTertiary"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="GCJ: 116.123456,39.123456"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp" />

            <!-- WGS84坐标 - 点击复制 -->
            <TextView
                android:id="@+id/tv_wgs84"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="11sp"
                android:textColor="@color/textTertiary"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="WGS: 116.123456,39.123456"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp" />

            <!-- 区域信息 - 仅区域显示 -->
            <LinearLayout
                android:id="@+id/layout_region_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_center_point"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/textTertiary"
                    android:fontFamily="monospace"
                    android:singleLine="true"
                    android:text="中心: 116.123,39.123" />

                <TextView
                    android:id="@+id/tv_radius"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="11sp"
                    android:textColor="@color/colorAccent"
                    android:text="半径: 100m" />
            </LinearLayout>
        </LinearLayout>

        <!-- 提示文字 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="点击坐标复制"
            android:textSize="9sp"
            android:textColor="@color/textTertiary"
            android:gravity="center" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
