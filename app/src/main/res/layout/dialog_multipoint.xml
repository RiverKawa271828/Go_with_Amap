<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/radius_xl"
    app:cardElevation="@dimen/elevation_high"
    app:cardBackgroundColor="@color/backgroundCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_2xl">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_multipoint_title"
            android:textAppearance="@style/TextAppearance.Title"
            android:textColor="@color/textPrimary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- 切换按钮 - 使用Segmented Button风格 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/md_surfaceContainer"
            android:layout_marginBottom="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_xs">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_history"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/btn_history"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/md_onSurface"
                    app:backgroundTint="@color/md_primary"
                    app:cornerRadius="@dimen/radius_sm"
                    android:elevation="2dp"
                    android:shadowColor="#40000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="4" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_favorites"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/btn_favorites"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/md_onSurfaceVariant"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/radius_sm"
                    android:elevation="0dp" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 历史列表容器 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/container_history"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="@color/backgroundLight"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp">

            <ListView
                android:id="@+id/lv_history"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:padding="0dp"
                android:scrollbars="vertical" />

        </com.google.android.material.card.MaterialCardView>

        <!-- 收藏列表容器 - 默认隐藏 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/container_favorites"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginBottom="@dimen/spacing_md"
            android:visibility="gone"
            app:cardBackgroundColor="@color/backgroundLight"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp">

            <ListView
                android:id="@+id/lv_favorites"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:padding="0dp"
                android:scrollbars="vertical" />

        </com.google.android.material.card.MaterialCardView>

        <!-- 已选择计数 -->
        <TextView
            android:id="@+id/tv_selected_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="已选择: 0 个坐标"
            android:textSize="@dimen/text_body"
            android:textColor="@color/colorPrimary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- 半径输入 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/AppTheme.TextInput"
            android:layout_marginBottom="@dimen/spacing_xl">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_radius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/dialog_multipoint_radius_hint"
                android:inputType="numberDecimal"
                android:textSize="@dimen/text_body" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 按钮区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                style="@style/AppTheme.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_cancel"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirm"
                style="@style/AppTheme.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_confirm"
                android:layout_marginStart="@dimen/spacing_sm" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
