<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/radius_xl"
    app:cardElevation="@dimen/elevation_high"
    app:cardBackgroundColor="@color/backgroundCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_2xl">

        <!-- 标题 -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="历史记录"
            android:textAppearance="@style/TextAppearance.Title"
            android:textColor="@color/textPrimary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- 搜索框 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/md_surfaceContainer"
            android:layout_marginBottom="@dimen/spacing_md">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/search_view"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                app:queryHint="搜索模拟记录..."
                app:iconifiedByDefault="false"
                android:background="@null" />

        </com.google.android.material.card.MaterialCardView>

        <!-- 历史记录列表容器 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/container_history"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="@color/backgroundLight"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp">

            <ListView
                android:id="@+id/lv_history"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:padding="0dp"
                android:scrollbars="vertical" />

        </com.google.android.material.card.MaterialCardView>

        <!-- 无记录提示 -->
        <TextView
            android:id="@+id/tv_no_record"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="暂无历史记录"
            android:textSize="@dimen/text_body"
            android:textColor="@color/textTertiary"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/spacing_xl" />

        <!-- 提示文字 -->
        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="点击右侧圆圈选择，点击条目在地图上显示"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/textTertiary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_xl" />

        <!-- 底部按钮 - 左边删除，中间分享，右边关闭 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear"
                style="@style/AppTheme.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:text="删除" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_share"
                style="@style/AppTheme.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:visibility="gone"
                android:text="分享" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_close"
                style="@style/AppTheme.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="关闭" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
