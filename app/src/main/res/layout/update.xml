<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_xl"
    android:orientation="vertical">

    <TextView
        android:id="@+id/update_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/update_title"
        android:textAppearance="?attr/textAppearanceHeadlineSmall"
        android:textColor="@color/md_onSurface"
        android:layout_marginBottom="@dimen/spacing_md" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:rowCount="2"
        android:columnCount="2">

        <TextView
            android:layout_column="0"
            android:layout_row="0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textStyle="bold"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:text="@string/update_time" />
        <TextView
            android:layout_row="0"
            android:layout_column="1"
            android:id="@+id/update_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:text="" />
        <TextView
            android:layout_row="1"
            android:layout_column="0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:text="@string/update_commit" />
        <TextView
            android:layout_row="1"
            android:layout_column="1"
            android:id="@+id/update_commit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:text="" />
    </GridLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_md"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardElevation="0dp"
        app:strokeColor="@color/md_outlineVariant"
        app:strokeWidth="1dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/update_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/spacing_md"
                android:lineSpacingMultiplier="1.2"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/md_onSurface" />
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/update_ignore"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="@string/update_ignore"
            style="@style/AppTheme.Button.Outlined" />

        <Space
            android:layout_width="60dp"
            android:layout_height="match_parent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/update_agree"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="@string/update_download"
            style="@style/AppTheme.Button" />
    </LinearLayout>
</LinearLayout>
