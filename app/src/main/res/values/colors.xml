<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================ -->
    <!-- Material Design 3 主题色系统 - 动态配色方案 -->
    <!-- ============================================ -->
    
    <!-- 主要品牌色 (Primary) - 活力蓝 -->
    <color name="md_primary">#006C4C</color>
    <color name="md_onPrimary">#FFFFFF</color>
    <color name="md_primaryContainer">#89F8C7</color>
    <color name="md_onPrimaryContainer">#002114</color>
    
    <!-- 次要品牌色 (Secondary) - 柔和青绿 -->
    <color name="md_secondary">#4D6357</color>
    <color name="md_onSecondary">#FFFFFF</color>
    <color name="md_secondaryContainer">#CFE9D9</color>
    <color name="md_onSecondaryContainer">#092016</color>
    
    <!-- 第三品牌色 (Tertiary) - 优雅紫 -->
    <color name="md_tertiary">#3D6373</color>
    <color name="md_onTertiary">#FFFFFF</color>
    <color name="md_tertiaryContainer">#C1E8FB</color>
    <color name="md_onTertiaryContainer">#001F29</color>
    
    <!-- 错误色 (Error) -->
    <color name="md_error">#BA1A1A</color>
    <color name="md_onError">#FFFFFF</color>
    <color name="md_errorContainer">#FFDAD6</color>
    <color name="md_onErrorContainer">#410002</color>
    
    <!-- 表面色 (Surface) - 现代浅色主题 -->
    <color name="md_surface">#FBFDF9</color>
    <color name="md_onSurface">#191C1A</color>
    <color name="md_surfaceVariant">#DCE5DD</color>
    <color name="md_onSurfaceVariant">#404943</color>
    <color name="md_surfaceTint">@color/md_primary</color>
    
    <!-- 背景色 (Background) -->
    <color name="md_background">#FBFDF9</color>
    <color name="md_onBackground">#191C1A</color>
    
    <!-- 轮廓色 (Outline) -->
    <color name="md_outline">#707973</color>
    <color name="md_outlineVariant">#BFC9C2</color>
    
    <!-- 表面容器色 - 用于卡片、对话框等 -->
    <color name="md_surfaceContainerLowest">#FFFFFF</color>
    <color name="md_surfaceContainerLow">#F5F5F5</color>
    <color name="md_surfaceContainer">#F0F0F0</color>
    <color name="md_surfaceContainerHigh">#EAEAEA</color>
    <color name="md_surfaceContainerHighest">#E0E0E0</color>
    
    <!-- 强调色 - 用于状态指示 -->
    <color name="md_success">#2E7D32</color>
    <color name="md_successContainer">#C8E6C9</color>
    <color name="md_warning">#F57C00</color>
    <color name="md_warningContainer">#FFE0B2</color>
    <color name="md_info">#1976D2</color>
    <color name="md_infoContainer">#BBDEFB</color>
    
    <!-- ============================================ -->
    <!-- 向后兼容的旧颜色引用 -->
    <!-- ============================================ -->
    <color name="colorPrimary">@color/md_primary</color>
    <color name="colorPrimaryDark">@color/md_primary</color>
    <color name="colorAccent">@color/md_secondary</color>
    
    <!-- 背景色兼容 -->
    <color name="backgroundLight">@color/md_background</color>
    <color name="backgroundCard">@color/md_surfaceContainerLowest</color>
    <color name="backgroundElevated">@color/md_surfaceContainerLow</color>
    <color name="backgroundDark">#1A1F36</color>
    
    <!-- 文字色兼容 -->
    <color name="textPrimary">@color/md_onSurface</color>
    <color name="textSecondary">@color/md_onSurfaceVariant</color>
    <color name="textTertiary">@color/md_outline</color>
    <color name="textLight">@color/md_onPrimary</color>
    
    <!-- 强调色兼容 -->
    <color name="accentSuccess">@color/md_success</color>
    <color name="accentWarning">@color/md_warning</color>
    <color name="accentError">@color/md_error</color>
    <color name="accentInfo">@color/md_info</color>
    
    <!-- 分割线 -->
    <color name="dividerColor">@color/md_outlineVariant</color>
    <color name="rippleColor">#1F000000</color>
    
    <!-- 渐变色 - 保留用于特殊效果 -->
    <color name="gradientStart">@color/md_primary</color>
    <color name="gradientEnd">@color/md_tertiary</color>
    <color name="gradientAccentStart">@color/md_secondary</color>
    <color name="gradientAccentEnd">@color/md_tertiary</color>
    
    <!-- ============================================ -->
    <!-- 基础颜色 - 保留用于兼容性 -->
    <!-- ============================================ -->
    <color name="white">#FFFFFF</color>
    <color name="black">#000000</color>
    <color name="transparent">#00000000</color>
    
    <!-- 常用灰度 -->
    <color name="gray50">#FAFAFA</color>
    <color name="gray100">#F5F5F5</color>
    <color name="gray200">#EEEEEE</color>
    <color name="gray300">#E0E0E0</color>
    <color name="gray400">#BDBDBD</color>
    <color name="gray500">#9E9E9E</color>
    <color name="gray600">#757575</color>
    <color name="gray700">#616161</color>
    <color name="gray800">#424242</color>
    <color name="gray900">#212121</color>

    <!-- 向后兼容的颜色 -->
    <color name="gray">@color/gray500</color>
    <color name="grey">@color/gray500</color>
    <color name="lightgrey">@color/gray300</color>
    
    <!-- 状态颜色 - 用于地图标记等 -->
    <color name="lightblue">#E3F2FD</color>
    <color name="lightgreen">#E8F5E9</color>
    <color name="lightyellow">#FFFDE7</color>
    <color name="lightred">#FFEBEE</color>
    
    <!-- ============================================ -->
    <!-- 夜间模式颜色定义（默认值，实际值在 values-night 中覆盖） -->
    <!-- ============================================ -->
    <color name="md_primary_dark">#6CDBAC</color>
    <color name="md_onPrimary_dark">#003826</color>
    <color name="md_primaryContainer_dark">#005138</color>
    <color name="md_onPrimaryContainer_dark">#89F8C7</color>
    <color name="md_secondary_dark">#B3CCBE</color>
    <color name="md_onSecondary_dark">#1F352A</color>
    <color name="md_secondaryContainer_dark">#354B40</color>
    <color name="md_onSecondaryContainer_dark">#CFE9D9</color>
    <color name="md_tertiary_dark">#A5CCDF</color>
    <color name="md_onTertiary_dark">#063544</color>
    <color name="md_tertiaryContainer_dark">#244D5B</color>
    <color name="md_onTertiaryContainer_dark">#C1E8FB</color>
    <color name="md_error_dark">#FFB4AB</color>
    <color name="md_onError_dark">#690005</color>
    <color name="md_errorContainer_dark">#93000A</color>
    <color name="md_onErrorContainer_dark">#FFDAD6</color>
    <color name="md_surface_dark">#191C1A</color>
    <color name="md_onSurface_dark">#E1E3DF</color>
    <color name="md_surfaceVariant_dark">#404943</color>
    <color name="md_onSurfaceVariant_dark">#BFC9C2</color>
    <color name="md_background_dark">#191C1A</color>
    <color name="md_onBackground_dark">#E1E3DF</color>
    <color name="md_outline_dark">#89938D</color>
    <color name="md_outlineVariant_dark">#404943</color>
    <color name="md_surfaceContainerLowest_dark">#0D0F0E</color>
    <color name="md_surfaceContainerLow_dark">#191C1A</color>
    <color name="md_surfaceContainer_dark">#1D201E</color>
    <color name="md_surfaceContainerHigh_dark">#272B28</color>
    <color name="md_surfaceContainerHighest_dark">#323633</color>
    
    <!-- 强调色 - 夜间模式 -->
    <color name="md_success_dark">#81C784</color>
    <color name="md_successContainer_dark">#1B5E20</color>
    <color name="md_warning_dark">#FFB74D</color>
    <color name="md_warningContainer_dark">#E65100</color>
    <color name="md_info_dark">#64B5F6</color>
    <color name="md_infoContainer_dark">#0D47A1</color>
    
</resources>
