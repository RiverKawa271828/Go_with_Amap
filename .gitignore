*.jks
*.keystore
keystore/*.jks
keystore/*.keystore
keystore/release/*
keystore/debug/*

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild

# Google Services (e.g. APIs or Firebase)
google-services.json

# Project specific
AGENTS.md
MIGRATION_GUIDE.md
